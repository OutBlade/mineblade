{
  "name": "void-survivors",
  "version": "1.0.0",
  "description": "Auto-Battler Roguelike",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder -w"
  },
  "author": "Claude Code Game Studios",
  "license": "MIT",
  "build": {
    "appId": "com.ccgs.voidsurvivors",
    "productName": "Void Survivors",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable"
    },
    "files": [
      "src/**/*",
      "main.js"
    ]
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1",
    "electron-packager": "^17.1.2"
  }
}
